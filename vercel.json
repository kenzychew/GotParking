{
  "regions": ["sin1"],
  "services": {
    "frontend": {
      "root": "frontend/"
    },
    "batch_predict": {
      "root": "api/",
      "framework": "python",
      "entrypoint": "batch_predict.py",
      "buildCommand": "D=lib; [ -d _lib ] || D=api/lib; mkdir -p $D && cp -v \"$(gcc -print-file-name=libgomp.so.1)\" $D/ && ls -la $D"
    },
    "forecast": {
      "root": "api/",
      "entrypoint": "forecast.py"
    },
    "geocode_postal": {
      "root": "api/",
      "entrypoint": "geocode_postal.py"
    }
  },
  "rewrites": [
    { "source": "/api/batch_predict", "destination": { "service": "batch_predict" } },
    { "source": "/api/forecast", "destination": { "service": "forecast" } },
    { "source": "/api/geocode_postal", "destination": { "service": "geocode_postal" } },
    { "source": "/(.*)", "destination": { "service": "frontend" } }
  ]
}
